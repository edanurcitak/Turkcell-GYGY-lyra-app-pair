<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Çevrimdışı durumunu algılamak için (ConnectivityManager); kütüphanede yalnızca indirilenleri göstermek. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Arka plan oynatma: medya oturumu foreground servis olarak çalışır. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Android 13+ medya bildirimini gösterebilmek için (runtime'da istenir). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".LyraApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LyraApp"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LyraApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Arka plan oynatmayı yöneten medya oturumu servisi. ExoPlayer + MediaSession sahibidir;
            Media3 bu oturumdan sistem medya bildirimini (görseldeki "mini player") üretir.
            exported=true → harici medya kontrolcüleri (sistem, Bluetooth vb.) bağlanabilir.
        -->
        <service
            android:name=".ui.player.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>

</manifest>